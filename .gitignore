# Entornos virtuales (Crucial para evitar los 34.000 objetos)
venv/
.venv/
env/

# Carpetas de base de datos específicas de tu proyecto
db_data/
__pycache__/

# --- RAG & AI Specific ---
# Ignorar los índices de FAISS (se deben regenerar localmente)
faiss_index/
index.faiss
index.pkl
*.index

# Ignorar los documentos que subas para probar (privacidad)
data/
documents/
uploads/
*.pdf
*.docx
*.csv
*.txt

# --- Ollama / Local LLM ---
# Si Ollama descarga modelos dentro de la carpeta del proyecto
models/
*.bin
*.gguf

# --- Persistent Storage ---
# Si usas bases de datos vectoriales persistentes (ChromaDB, etc.)
vector_db/
chroma_db/

# --- Streamlit ---
# Ignorar archivos temporales de carga de Streamlit
.streamlit/
! .streamlit/config.toml  